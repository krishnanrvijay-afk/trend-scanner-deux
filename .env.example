# ── Supabase — required for state persistence ─────────────────────────────────
# Scanner state, trade log, and paper trades are persisted to Supabase.
# If omitted, the app runs without persistence (state resets on restart).
SUPABASE_URL=
SUPABASE_KEY=

# ── Hyperliquid — required for live trading (optional in PAPER_MODE) ──────────
# HL_PRIVATE_KEY is only used when PAPER_MODE=False to sign orders.
# HL_WALLET_ADDRESS is used for account-level queries (positions, balances).
HL_PRIVATE_KEY=
HL_WALLET_ADDRESS=

# ── MEXC — optional, only needed for live MEXC order execution ────────────────
# Leave blank to disable MEXC order routing; scanner still reads MEXC market data.
MEXC_API_KEY=
MEXC_SECRET_KEY=
